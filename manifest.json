{
  "manifest_version": 3,
  "name": "poe.ninja → POE2 Trade",
  "short_name": "Ninja Trade",
  "version": "0.1.26134.27022",
  "description": "Agrega un botón de búsqueda en los ítems de poe.ninja para buscarlos directamente en el trade de Path of Exile 2.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "poe.ninja → POE2 Trade"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://poe.ninja/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://poe.ninja/*",
    "https://www.pathofexile.com/*"
  ],
  "version_name": "v0.1.260514.642"
}